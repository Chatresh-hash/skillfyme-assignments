FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci --only=production
COPY . .
RUN apk add --no-cache curl 

FROM node:20-alpine
WORKDIR /app
RUN addgroup -S bankgroup && adduser -S bankuser -G bankgroup
COPY --from=builder --chown=bankuser:bankgroup /app/node_modules ./node_modules
COPY --chown=bankuser:bankgroup . .
USER bankuser
EXPOSE 3000
ENV NODE_ENV=production
CMD ["node", "server.js"]